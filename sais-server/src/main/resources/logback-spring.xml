<configuration>
    <!-- Refer to org/springframework/boot/logging/logback/defaults.xml to optimize CONSOLE_LOG_PATTERN and FILE_LOG_PATTERN -->
    <!-- Formatted output: %d is date, %thread is thread name, %-5level is left-aligned level width, %msg is log message, and %n is newline -->
    <!-- CONSOLE_LOG_PATTERN adds highlight, cyan, and other coloring compared with FILE_LOG_PATTERN -->
    <property name="CONSOLE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{50}:%L) - %msg%n"/>
    <property name="FILE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%L - %msg%n"/>

    <!-- Console Appender -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">　　　　　
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- File Appender -->
    <!-- Written with reference to Spring Boot's file-appender.xml -->
    <appender name="FILE"  class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>
        <!-- Log file name -->
        <file>${LOG_FILE}</file>
        <!-- Rolling policy: create log files based on day and size -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern> <!-- Output file name for log files -->
            <maxHistory>30</maxHistory> <!-- Number of days to retain log files -->
            <maxFileSize>10MB</maxFileSize> <!-- Roll log files when this size is reached -->
        </rollingPolicy>
    </appender>
    <!-- Write logs asynchronously to improve performance -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold> <!-- Do not discard logs. By default, TRACE, DEBUG, and INFO logs are discarded when the queue is 80% full -->
        <queueSize>512</queueSize> <!-- Change the default queue depth. This affects performance. The default is 256 -->
        <appender-ref ref="FILE"/>
    </appender>

    <!-- SkyWalking Appender: GRPC log collection for the log center -->
    <!--
    <appender name="SKYWALKING" class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.log.GRPCLogClientAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.TraceIdPatternLogbackLayout">
                <pattern>[%tid] ${FILE_LOG_PATTERN}</pattern>
            </layout>
        </encoder>
    </appender>
    -->

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <!-- In the local environment, comment out this line if you do not want FILE logging -->
        <appender-ref ref="ASYNC"/>
        <!-- Uncomment this line to connect to the SkyWalking log service -->
        <!-- <appender-ref ref="SKYWALKING"/> -->
    </root>

</configuration>
